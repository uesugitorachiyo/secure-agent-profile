  "policy": "policy/secure-agent.policy.yaml",
  "evidence_pack": {"required": true, "template": "secure-agent"},
  "inputs": {
    "brief": {"required": true, "type": "path"},
    "repo": {"required": true, "type": "path"},
    "dry_run": {"required": false, "type": "boolean", "default": false}
