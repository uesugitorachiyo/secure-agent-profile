  "roles": [
    {"id": "intake", "skill": "skills/secure-agent/intake.md", "deps": [], "host_tags": ["repo-safe"]},
    {"id": "repo-scan", "skill": "skills/secure-agent/repo-scan.md", "deps": ["intake"], "host_tags": ["repo-safe"]},
    {"id": "scope-classify", "skill": "skills/secure-agent/risk-classifier.md", "deps": ["repo-scan"], "host_tags": ["repo-safe"]},
    {"id": "risk-classify", "skill": "skills/secure-agent/risk-classifier.md", "deps": ["scope-classify"], "host_tags": ["repo-safe"]},
    {"id": "guarded-plan", "skill": "skills/secure-agent/guarded-plan.md", "deps": ["risk-classify"], "host_tags": ["live-codex"]},
    {"id": "implementation", "skill": "skills/secure-agent/implementation.md", "deps": ["guarded-plan"], "host_tags": ["live-codex"]},
    {"id": "verifier-run", "skill": "skills/secure-agent/closure.md", "deps": ["implementation"], "host_tags": ["repo-safe"]},
    {"id": "security-review", "skill": "skills/secure-agent/security-review.md", "deps": ["verifier-run"], "host_tags": ["repo-safe"]},
    {"id": "closure", "skill": "skills/secure-agent/closure.md", "deps": ["security-review"], "host_tags": ["repo-safe"]}
  ]
